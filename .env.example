# VoteSecure Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=production

# Session secret (generate a random 64-char string for production)
SESSION_SECRET=change-this-to-a-very-long-random-secret-string-in-production

# Allowed CORS origin (set to your Railway domain)
ALLOWED_ORIGIN=https://your-app.railway.app
